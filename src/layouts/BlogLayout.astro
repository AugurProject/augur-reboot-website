---
import ArticleContent from "../components/content/article-content.astro";
import Footer from "../components/shell/footer.astro";
import PageHeader from "../components/shell/page-header.tsx";
import PageTitle from "../components/shell/page-title.astro";
import BlogNavigation from "../features/blog/navigation.tsx";
import BlogPostMeta from "../features/blog/post-meta.astro";
import Layout from "../layouts/Layout.astro";

interface Post {
	title: string;
	path: string;
}

interface Props {
	title: string;
	description?: string;
	author: string;
	publishDate: Date;
	updatedDate?: Date;
	ogImage?: string;
	postUrl?: string;
	prevPost?: Post;
	nextPost?: Post;
}

const {
	title,
	description,
	author,
	publishDate,
	updatedDate,
	ogImage,
	prevPost,
	nextPost,
} = Astro.props;
---

<Layout
  title={`${title} - The Augur Blog`}
  description={description}
  ogImage={ogImage}
  ogType="article"
>
  <div class="grid grid-rows-[auto_1fr_auto] min-h-screen">
    {/* Top Section: Navigation */}
    <PageHeader client:load backHref="/" />

    {/* Middle Section: Scrollable Content */}
    <main class="overflow-y-auto px-4 md:px-8 pt-8 mb-12">
      <div class="max-w-3xl mx-auto">
        <PageTitle prefix="BLOG" title={title} />
        <BlogPostMeta
          author={author}
          publishDate={publishDate}
          updatedDate={updatedDate}
        />

        {/* Main Content */}
        <ArticleContent>
          <slot />
        </ArticleContent>
      </div>
    </main>

    {/* Bottom Section: Navigation + Footer */}
    <BlogNavigation client:load prevPost={prevPost} nextPost={nextPost} />
    <Footer />
  </div>

  <style is:global>
    /* Corner accent decorations for blog post articles */
    .prose > :first-child {
      position: relative;
    }

    .prose > :first-child + p:has(img)::after,
    .prose > :first-child::before {
        position: absolute;
        content: '';
        width: 2rem;
        height: 2rem;
    }

    .prose > :first-child::before {
      top: -1rem;
      left: -1rem;
      border-top: 1px solid var(--color-muted-foreground);
      border-left: 1px solid var(--color-muted-foreground);
    }

    .prose > :first-child + p:has(img) {
      position: relative;
    }

    .prose > :first-child + p:has(img)::after {
      bottom: -1rem;
      right: -1rem;
      border-bottom: 1px solid var(--color-muted-foreground);
      border-right: 1px solid var(--color-muted-foreground);
    }
  </style>
</Layout>

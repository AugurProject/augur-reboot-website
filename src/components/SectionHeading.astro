---
export interface Props {
  text: string;
  class?: string;
}

const { text, class: className = "" } = Astro.props;
---

<div class="flex justify-center mb-6">
  <h2 class={`text-loud-foreground font-display tracking-wider font-light uppercase border border-primary/30 px-2 py-1 ${className}`}>
    {text}
  </h2>
</div>

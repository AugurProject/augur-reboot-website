---
export interface Props {
  question: string;
}

const { question } = Astro.props;
---

<details class="faq-item mb-0.5">
  <summary class="flex items-center gap-3 p-4 cursor-pointer list-none text-foreground tracking-wide font-display uppercase select-none transition-colors duration-200 rounded">
    {question}
  </summary>
  <div class="faq-answer p-4 pl-11 text-sm leading-relaxed text-foreground normal-case rounded-b">
    <slot />
  </div>
</details>

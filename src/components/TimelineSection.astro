---
interface Props {
  title: string;
  date?: string;
  isLast?: boolean;
}

const { title, date, isLast = false } = Astro.props;
---

<div
  class:list={[
    "relative grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-8 items-start",
    { "mb-16": !isLast },
  ]}
>
  <div class="font-display lg:text-right lg:pr-8 uppercase">
    <div class="mb-2">{date}</div>
    <h2 class="text-2xl text-loud-foreground font-bold">{title}</h2>
  </div>
  <div class="relative pl-8 normal-case [&_h3]:text-loud-foreground [&_h3]:text-lg [&_h3]:font-bold [&_h3]:mb-2 [&_h3]:uppercase [&_h3]:tracking-wide [&_ul]:my-4 [&_ul]:pl-6 [&_ul]:list-disc [&_li]:mb-1 [&_p+p]:mt-4 [&_strong]:text-loud-foreground [&_strong]:font-bold [&_em]:text-loud-foreground [&_em]:italic [&_a]:text-loud-foreground [&_a]:underline [&_a]:underline-offset-2 [&_a:hover]:drop-shadow-[0_0_0.375rem_var(--color-primary)] before:content-[''] before:absolute before:left-0 before:top-2 before:w-2.5 before:h-2.5 before:border before:border-loud-foreground before:rounded-full">
    <slot />
  </div>
</div>
